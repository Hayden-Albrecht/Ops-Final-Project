import time
import sys

import qwiic_keypad
import qwiic_serlcd
import qwiic_buzzer


def get_four_keys(keypad, lcd):
    entered = ""

    lcd.clearScreen()
    lcd.setCursor(0, 0)
    lcd.print("Enter 4 keys:")

    while len(entered) < 4:
        keypad.update_fifo()
        button = keypad.get_button()

        if button != 0:
            char = chr(button)
            entered += char
            print(f"Key pressed: {char}")

            # Show progress on second line
            lcd.setCursor(0, 1)
            lcd.print(" " * 16)
            lcd.setCursor(0, 1)
            lcd.print(entered)

            # Small debounce delay
            time.sleep(0.15)

        # Short poll delay so loop stays responsive
        time.sleep(0.02)

    return entered


def buzz_three_times(buzzer):
    for _ in range(3):
        buzzer.on()
        time.sleep(0.15)
        buzzer.off()
        time.sleep(0.15)


def main():
    keypad = qwiic_keypad.QwiicKeypad()
    lcd = qwiic_serlcd.QwiicSerlcd()
    buzzer = qwiic_buzzer.QwiicBuzzer()

    if not keypad.begin():
        print("Keypad not detected.", file=sys.stderr)
        return

    if not lcd.connected:
        print("LCD not detected.", file=sys.stderr)
        return

    if not buzzer.begin():
        print("Buzzer not detected.", file=sys.stderr)
        return

    lcd.setBacklight(255, 255, 255)
    lcd.setContrast(5)
    lcd.clearScreen()

    entered = get_four_keys(keypad, lcd)
    print(f"4 keys entered: {entered}")

    lcd.clearScreen()
    lcd.setCursor(0, 0)
    lcd.print("Hello!")
    lcd.setCursor(0, 1)
    lcd.print("You typed:")
    time.sleep(1.0)

    lcd.clearScreen()
    lcd.setCursor(0, 0)
    lcd.print("Input:")
    lcd.setCursor(0, 1)
    lcd.print(entered[:16])

    buzz_three_times(buzzer)


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\nProgram stopped.")

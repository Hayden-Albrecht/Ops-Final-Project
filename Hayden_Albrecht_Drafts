# =========================================================
# LOGGING
# =========================================================
def timestamp_string() -> str:
    return time.strftime("%Y-%m-%d %H:%M:%S")


def log_event(event_type: str, result: str, details: str = "") -> None:
    """
    Append a single audit line to the log file.
    Logging failures are intentionally ignored so they never crash the app.
    """
    try:
        with open(LOG_FILE, "a", encoding="utf-8") as f:
            f.write(f"{timestamp_string()} | {result} | {event_type} | {details}\n")
            f.flush()
            os.fsync(f.fileno())
    except Exception:
        pass


# =========================================================
# DATABASE HELPERS
# =========================================================
def save_database(db: Dict[str, Any]) -> None:
    temp_path = DATA_FILE + ".tmp"
    with open(temp_path, "w", encoding="utf-8") as f:
        json.dump(db, f, indent=2)
        f.flush()
        os.fsync(f.fileno())
    os.replace(temp_path, DATA_FILE)


def load_database() -> Dict[str, Any]:
    if not os.path.exists(DATA_FILE):
        db = default_database()
        save_database(db)
        log_event("system", "INFO", "created_default_database")
        return db

    with open(DATA_FILE, "r", encoding="utf-8") as f:
        db = json.load(f)

    if "users" not in db or not isinstance(db["users"], list):
        raise RuntimeError("Invalid database structure")

    return db


def normalize_tag(tag: str) -> str:
    return str(tag).strip().upper()


def find_user_by_password(db: Dict[str, Any], password: str) -> Optional[Dict[str, Any]]:
    for user in db["users"]:
        if user.get("active", True) and user.get("password") == password:
            return user
    return None


def find_user_by_rfid(db: Dict[str, Any], rfid: str) -> Optional[Dict[str, Any]]:
    target = normalize_tag(rfid)
    for user in db["users"]:
        if user.get("active", True) and normalize_tag(user.get("rfid", "")) == target:
            return user
    return None


def count_active_admins(db: Dict[str, Any]) -> int:
    total = 0
    for user in db["users"]:
        if user.get("active", True) and user.get("role") == ROLE_ADMIN:
            total += 1
    return total


def add_user(db: Dict[str, Any], password: str, rfid: str, role: str) -> None:
    if role not in VALID_ROLES:
        raise ValueError("Invalid role")

    if find_user_by_password(db, password) is not None:
        raise ValueError("Password exists")

    if find_user_by_rfid(db, rfid) is not None:
        raise ValueError("RFID exists")

    db["users"].append({
        "password": password,
        "rfid": normalize_tag(rfid),
        "role": role,
        "active": True
    })
    save_database(db)


def remove_user(db: Dict[str, Any], password: str, rfid: str) -> bool:
    target_rfid = normalize_tag(rfid)

    for user in db["users"]:
        if not user.get("active", True):
            continue

        if user.get("password") == password and normalize_tag(user.get("rfid", "")) == target_rfid:
            if user.get("role") == ROLE_ADMIN and count_active_admins(db) <= 1:
                raise ValueError("Cannot remove last admin")

            user["active"] = False
            save_database(db)
            return True

    return False



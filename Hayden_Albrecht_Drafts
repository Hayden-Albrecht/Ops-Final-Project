def init_lcd():
    lcd = qwiic_serlcd.QwiicSerlcd()
    if not lcd.is_connected():
        raise RuntimeError("SerLCD not connected")
    lcd.begin()
    time.sleep(0.20)
    lcd.clearScreen()
    time.sleep(0.20)
    return lcd


def init_keypad():
    keypad = qwiic_keypad.QwiicKeypad()
    if not keypad.is_connected():
        raise RuntimeError("Keypad not connected")
    keypad.begin()
    return keypad


def init_rfid():
    rfid = qwiic_rfid.QwiicRFID()
    if not rfid.is_connected():
        raise RuntimeError("RFID reader not connected")
    rfid.begin()
    return rfid


def init_buzzer():
    buzzer = qwiic_buzzer.QwiicBuzzer()
    if not buzzer.is_connected():
        raise RuntimeError("Buzzer not connected")
    buzzer.begin()
    return buzzer


# =========================================================
# LCD HELPERS
# =========================================================
def _pad_16(text: str) -> str:
    return (text or "")[:16].ljust(16)


def lcd_show(lcd, line1: str = "", line2: str = "", force: bool = False):
    global _last_lcd_line1, _last_lcd_line2, _last_lcd_time

    now = time.time()
    line1 = _pad_16(line1)
    line2 = _pad_16(line2)

    changed = (line1 != _last_lcd_line1) or (line2 != _last_lcd_line2)

    if not changed and not force:
        return

    if not force and (now - _last_lcd_time) < LCD_MIN_UPDATE_INTERVAL:
        return

    try:
        if force or line1 != _last_lcd_line1:
            lcd.setCursor(0, 0)
            time.sleep(0.01)
            lcd.print(line1)
            time.sleep(0.02)

        if force or line2 != _last_lcd_line2:
            lcd.setCursor(0, 1)
            time.sleep(0.01)
            lcd.print(line2)
            time.sleep(0.02)

        _last_lcd_line1 = line1
        _last_lcd_line2 = line2
        _last_lcd_time = time.time()

    except Exception:
        time.sleep(0.20)


def lcd_message(lcd, line1: str = "", line2: str = "", pause: float = POST_MESSAGE_DELAY):
    lcd_show(lcd, line1, line2, force=True)
    time.sleep(pause)


# =========================================================
# BUZZER HELPERS
# =========================================================
def _try_configure_buzzer(buzzer, frequency_hz: int, duration_ms: int) -> bool:
    for method_name in ("configureBuzzer", "configure_buzzer"):
        method = getattr(buzzer, method_name, None)
        if callable(method):
            method(frequency_hz, duration_ms)
            return True

    set_freq = getattr(buzzer, "set_frequency", None)
    set_dur = getattr(buzzer, "set_duration", None)
    if callable(set_freq) and callable(set_dur):
        set_freq(frequency_hz)
        set_dur(duration_ms)
        return True

    return False


def beep(buzzer, frequency_hz: int, duration_ms: int):
    _try_configure_buzzer(buzzer, frequency_hz, duration_ms)
    buzzer.on()
    time.sleep(duration_ms / 1000.0)
    buzzer.off()
    time.sleep(0.08)


def success_beep(buzzer):
    beep(buzzer, 2500, 140)


def fail_beep(buzzer):
    beep(buzzer, 350, 400)


# =========================================================
# KEYPAD HELPERS
# =========================================================
def flush_keypad(keypad, seconds: float = 0.6):
    end = time.time() + seconds
    while time.time() < end:
        keypad.update_fifo()
        _ = keypad.get_button()
        time.sleep(KEYPAD_POLL_DELAY)


def read_keypad_char(keypad) -> Optional[str]:
    keypad.update_fifo()
    button = keypad.get_button()

    if not button:
        return None

    try:
        return chr(button)
    except TypeError:
        return str(button)


def get_passcode_from_keypad_forever(
    lcd,
    keypad,
    prompt1: str = "Enter passcode",
    prompt2: str = "then press #"
) -> str:
    entered = ""
    last_masked = None

    lcd_show(lcd, prompt1, prompt2, force=True)

    while True:
        ch = read_keypad_char(keypad)

        if ch is None:
            time.sleep(KEYPAD_POLL_DELAY)
            continue

        if ch == "#":
            time.sleep(POST_KEY_DELAY)
            return entered

        if ch == "*":
            entered = ""
        elif ch.isdigit():
            entered += ch

        masked = "*" * len(entered)
        if masked != last_masked:
            lcd_show(lcd, prompt1, masked, force=True)
            last_masked = masked

        time.sleep(POST_KEY_DELAY)


def get_passcode_from_keypad_timeout(
    lcd,
    keypad,
    timeout_s: int,
    prompt1: str = "Enter passcode",
    prompt2: str = "then press #"
) -> Optional[str]:
    entered = ""
    last_masked = None
    start = time.time()

    lcd_show(lcd, prompt1, prompt2, force=True)

    while time.time() - start < timeout_s:
        ch = read_keypad_char(keypad)

        if ch is None:
            time.sleep(KEYPAD_POLL_DELAY)
            continue

        if ch == "#":
            time.sleep(POST_KEY_DELAY)
            return entered

        if ch == "*":
            entered = ""
        elif ch.isdigit():
            entered += ch

        masked = "*" * len(entered)
        if masked != last_masked:
            lcd_show(lcd, prompt1, masked, force=True)
            last_masked = masked

        time.sleep(POST_KEY_DELAY)

    return None


def get_role_selection(lcd, keypad, allowed_roles: List[str]) -> Optional[str]:
    options = []
    mapping = {}

    if ROLE_EMPLOYEE in allowed_roles:
        options.append("1=Emp")
        mapping["1"] = ROLE_EMPLOYEE
    if ROLE_MANAGER in allowed_roles:
        options.append("2=Mgr")
        mapping["2"] = ROLE_MANAGER
    if ROLE_ADMIN in allowed_roles:
        options.append("3=Adm")
        mapping["3"] = ROLE_ADMIN

    line1 = " ".join(options)[:16]
    lcd_show(lcd, "Choose role", line1, force=True)

    start = time.time()
    while time.time() - start < 30:
        ch = read_keypad_char(keypad)
        if ch in mapping:
            time.sleep(POST_KEY_DELAY)
            return mapping[ch]
        time.sleep(KEYPAD_POLL_DELAY)

    return None


# =========================================================
# RFID HELPERS
# =========================================================
def read_rfid_once(rfid) -> Optional[str]:
    raw_tag = rfid.get_tag()

    if raw_tag is None:
        return None

    tag = normalize_tag(raw_tag)

    if tag in {"", "NONE", "0", "00", "0000", "000000", "0000000000"}:
        return None

    return tag


def wait_for_rfid_scan(lcd, rfid, prompt1: str, prompt2: str, timeout_s: int) -> Optional[str]:
    lcd_show(lcd, prompt1, prompt2, force=True)

    start = time.time()
    while time.time() - start < timeout_s:
        tag = read_rfid_once(rfid)
        if tag is not None:
            return tag
        time.sleep(RFID_POLL_DELAY)

    return None


# =========================================================
# AUTH HELPERS
# =========================================================
def login_flow(lcd, keypad, buzzer, db: Dict[str, Any]) -> Optional[Dict[str, Any]]:
    password = get_passcode_from_keypad_forever(
        lcd, keypad,
        "Startup password",
        "then press #"
    )

    if not password:
        lcd_message(lcd, "Enter password", "", 0.8)
        fail_beep(buzzer)
        log_event("login", "FAIL", "reason=empty_password")
        return None

    user = find_user_by_password(db, password)

    if user is None:
        lcd_message(lcd, "Invalid password", "", 0.8)
        fail_beep(buzzer)
        log_event("login", "FAIL", f"reason=invalid_password password={password}")
        return None

    lcd_message(lcd, "Role:", user["role"], 0.8)
    success_beep(buzzer)
    log_event("login", "SUCCESS", f"password={user['password']} role={user['role']}")
    return user


def reauth_password_and_rfid(lcd, keypad, rfid, buzzer, db: Dict[str, Any], expected_user: Dict[str, Any]) -> bool:
    password = get_passcode_from_keypad_timeout(
        lcd, keypad, 30,
        "Re-enter pass",
        "then press #"
    )

    if password is None:
        lcd_message(lcd, "Password timed", "out", 0.8)
        fail_beep(buzzer)
        log_event("reauth", "FAIL", f"user={expected_user['password']} reason=password_timeout")
        return False

    if password != expected_user["password"]:
        lcd_message(lcd, "Bad password", "", 0.8)
        fail_beep(buzzer)
        log_event("reauth", "FAIL", f"user={expected_user['password']} reason=bad_password")
        return False

    tag = wait_for_rfid_scan(
        lcd, rfid,
        "Scan your RFID",
        "for auth",
        RFID_SCAN_TIMEOUT_SECONDS
    )

    if tag is None:
        lcd_message(lcd, "RFID timed out", "", 0.8)
        fail_beep(buzzer)
        log_event("reauth", "FAIL", f"user={expected_user['password']} reason=rfid_timeout")
        return False

    if normalize_tag(tag) != normalize_tag(expected_user["rfid"]):
        lcd_message(lcd, "Invalid RFID", "", 0.8)
        fail_beep(buzzer)
        log_event("reauth", "FAIL", f"user={expected_user['password']} reason=bad_rfid scanned={normalize_tag(tag)}")
        return False

    lcd_message(lcd, "Authorized", "", 0.7)
    success_beep(buzzer)
    log_event("reauth", "SUCCESS", f"user={expected_user['password']} role={expected_user['role']}")
    return True


# =========================================================
# MENU
# =========================================================
def show_menu_for_role(lcd, role: str):
    if role == ROLE_EMPLOYEE:
        lcd_show(lcd, "1:Unlock 2:Lock", "", force=True)
    elif role == ROLE_MANAGER:
        lcd_show(lcd, "1U 2L 3:Add", "", force=True)
    elif role == ROLE_ADMIN:
        lcd_show(lcd, "1U 2L 3A 4R", "", force=True)
    else:
        lcd_show(lcd, "No role menu", "", force=True)


def valid_choices_for_role(role: str) -> set:
    if role == ROLE_EMPLOYEE:
        return {"1", "2"}
    if role == ROLE_MANAGER:
        return {"1", "2", "3"}
    if role == ROLE_ADMIN:
        return {"1", "2", "3", "4"}
    return set()


def wait_for_menu_choice(lcd, keypad, role: str) -> Optional[str]:
    valid = valid_choices_for_role(role)
    show_menu_for_role(lcd, role)

    while True:
        ch = read_keypad_char(keypad)
        if ch in valid:
            time.sleep(POST_KEY_DELAY)
            return ch
        time.sleep(KEYPAD_POLL_DELAY)


# =========================================================
# ACTION FLOWS
# =========================================================
def unlock_flow(lcd, rfid, buzzer, logged_in_user: Dict[str, Any]):
    tag = wait_for_rfid_scan(
        lcd,
        rfid,
        "Unlock: scan",
        "your RFID",
        RFID_SCAN_TIMEOUT_SECONDS
    )

    if tag is None:
        lcd_message(lcd, "No RFID scan", "", 0.8)
        fail_beep(buzzer)
        log_event("unlock", "FAIL", f"user={logged_in_user['password']} role={logged_in_user['role']} reason=rfid_timeout")
        return

    scanned = normalize_tag(tag)
    expected = normalize_tag(logged_in_user["rfid"])

    if scanned == expected:
        lcd_message(lcd, "Unlocked", "", 0.8)
        success_beep(buzzer)
        log_event("unlock", "SUCCESS", f"user={logged_in_user['password']} role={logged_in_user['role']}")
    else:
        lcd_message(lcd, "Invalid RFID", "Access denied", 0.8)
        fail_beep(buzzer)
        log_event("unlock", "FAIL", f"user={logged_in_user['password']} role={logged_in_user['role']} reason=bad_rfid scanned={scanned}")


def lock_flow(lcd, keypad, buzzer, logged_in_user: Dict[str, Any], db: Dict[str, Any]):
    password = get_passcode_from_keypad_timeout(
        lcd,
        keypad,
        30,
        "Lock: re-enter",
        "pass then #"
    )

    if password is None:
        lcd_message(lcd, "Password timed", "out", 0.8)
        fail_beep(buzzer)
        log_event("lock", "FAIL", f"user={logged_in_user['password']} role={logged_in_user['role']} reason=password_timeout")
        return

    current_user = find_user_by_password(db, password)

    if current_user is None or current_user["password"] != logged_in_user["password"]:
        lcd_message(lcd, "Invalid password", "", 0.8)
        fail_beep(buzzer)
        log_event("lock", "FAIL", f"user={logged_in_user['password']} role={logged_in_user['role']} reason=bad_password")
        return

    lcd_message(lcd, "Locked", "", 0.8)
    success_beep(buzzer)
    log_event("lock", "SUCCESS", f"user={logged_in_user['password']} role={logged_in_user['role']}")


def add_user_flow(lcd, keypad, rfid, buzzer, db: Dict[str, Any], logged_in_user: Dict[str, Any]):
    if not reauth_password_and_rfid(lcd, keypad, rfid, buzzer, db, logged_in_user):
        log_event("add_user", "FAIL", f"by={logged_in_user['password']} role={logged_in_user['role']} reason=reauth_failed")
        return

    if logged_in_user["role"] == ROLE_MANAGER:
        new_role = ROLE_EMPLOYEE
        lcd_message(lcd, "Adding role:", "employee", 0.8)
    else:
        new_role = get_role_selection(lcd, keypad, [ROLE_EMPLOYEE, ROLE_MANAGER, ROLE_ADMIN])

        if new_role is None:
            lcd_message(lcd, "Role timeout", "", 0.8)
            fail_beep(buzzer)
            log_event("add_user", "FAIL", f"by={logged_in_user['password']} role={logged_in_user['role']} reason=role_timeout")
            return

    new_password = get_passcode_from_keypad_timeout(
        lcd, keypad, 30,
        "New user pass",
        "then press #"
    )

    if not new_password:
        lcd_message(lcd, "Bad password", "entry", 0.8)
        fail_beep(buzzer)
        log_event("add_user", "FAIL", f"by={logged_in_user['password']} role={logged_in_user['role']} reason=empty_password")
        return

    if len(new_password) < 4:
        lcd_message(lcd, "Pass too short", "min 4 digits", 0.8)
        fail_beep(buzzer)
        log_event("add_user", "FAIL", f"by={logged_in_user['password']} role={logged_in_user['role']} reason=password_too_short")
        return

    if find_user_by_password(db, new_password) is not None:
        lcd_message(lcd, "Password exists", "", 0.8)
        fail_beep(buzzer)
        log_event("add_user", "FAIL", f"by={logged_in_user['password']} role={logged_in_user['role']} reason=password_exists")
        return

    new_tag = wait_for_rfid_scan(
        lcd, rfid,
        "Scan new RFID",
        "for new user",
        RFID_SCAN_TIMEOUT_SECONDS
    )

    if new_tag is None:
        lcd_message(lcd, "No RFID scan", "", 0.8)
        fail_beep(buzzer)
        log_event("add_user", "FAIL", f"by={logged_in_user['password']} role={logged_in_user['role']} reason=rfid_timeout")
        return

    new_tag = normalize_tag(new_tag)

    if find_user_by_rfid(db, new_tag) is not None:
        lcd_message(lcd, "RFID exists", "", 0.8)
        fail_beep(buzzer)
        log_event("add_user", "FAIL", f"by={logged_in_user['password']} role={logged_in_user['role']} reason=rfid_exists")
        return

    try:
        add_user(db, new_password, new_tag, new_role)
        lcd_message(lcd, "User added", new_role, 0.9)
        success_beep(buzzer)
        log_event("add_user", "SUCCESS", f"by={logged_in_user['password']} by_role={logged_in_user['role']} new_password={new_password} new_rfid={new_tag} new_role={new_role}")
    except Exception as exc:
        lcd_message(lcd, "Add failed", str(exc)[:16], 0.9)
        fail_beep(buzzer)
        log_event("add_user", "FAIL", f"by={logged_in_user['password']} by_role={logged_in_user['role']} reason=exception message={str(exc)}")


def remove_user_flow(lcd, keypad, rfid, buzzer, db: Dict[str, Any], logged_in_user: Dict[str, Any]):
    if logged_in_user["role"] != ROLE_ADMIN:
        lcd_message(lcd, "Not allowed", "", 0.8)
        fail_beep(buzzer)
        log_event("remove_user", "FAIL", f"by={logged_in_user['password']} role={logged_in_user['role']} reason=not_admin")
        return

    if not reauth_password_and_rfid(lcd, keypad, rfid, buzzer, db, logged_in_user):
        log_event("remove_user", "FAIL", f"by={logged_in_user['password']} role={logged_in_user['role']} reason=reauth_failed")
        return

    remove_password = get_passcode_from_keypad_timeout(
        lcd, keypad, 30,
        "Remove passcode",
        "then press #"
    )

    if not remove_password:
        lcd_message(lcd, "Bad password", "entry", 0.8)
        fail_beep(buzzer)
        log_event("remove_user", "FAIL", f"by={logged_in_user['password']} role={logged_in_user['role']} reason=empty_remove_password")
        return

    remove_tag = wait_for_rfid_scan(
        lcd, rfid,
        "Scan user's RFID",
        "to remove",
        RFID_SCAN_TIMEOUT_SECONDS
    )

    if remove_tag is None:
        lcd_message(lcd, "No RFID scan", "", 0.8)
        fail_beep(buzzer)
        log_event("remove_user", "FAIL", f"by={logged_in_user['password']} role={logged_in_user['role']} reason=rfid_timeout")
        return

    remove_tag = normalize_tag(remove_tag)

    target = None
    for user in db["users"]:
        if user.get("active", True) and user["password"] == remove_password and normalize_tag(user["rfid"]) == remove_tag:
            target = user
            break

    if target is None:
        lcd_message(lcd, "User not found", "", 0.8)
        fail_beep(buzzer)
        log_event("remove_user", "FAIL", f"by={logged_in_user['password']} role={logged_in_user['role']} reason=user_not_found")
        return

    if target["password"] == logged_in_user["password"] and normalize_tag(target["rfid"]) == normalize_tag(logged_in_user["rfid"]):
        lcd_message(lcd, "Cannot remove", "current admin", 0.8)
        fail_beep(buzzer)
        log_event("remove_user", "FAIL", f"by={logged_in_user['password']} role={logged_in_user['role']} reason=cannot_remove_self")
        return

    try:
        removed = remove_user(db, remove_password, remove_tag)
        if removed:
            lcd_message(lcd, "User removed", "", 0.8)
            success_beep(buzzer)
            log_event("remove_user", "SUCCESS", f"by={logged_in_user['password']} by_role={logged_in_user['role']} removed_password={remove_password} removed_rfid={remove_tag} removed_role={target['role']}")
        else:
            lcd_message(lcd, "Remove failed", "", 0.8)
            fail_beep(buzzer)
            log_event("remove_user", "FAIL", f"by={logged_in_user['password']} by_role={logged_in_user['role']} reason=remove_returned_false")
    except Exception as exc:
        lcd_message(lcd, "Remove failed", str(exc)[:16], 0.9)
        fail_beep(buzzer)
        log_event("remove_user", "FAIL", f"by={logged_in_user['password']} by_role={logged_in_user['role']} reason=exception message={str(exc)}")


# =========================================================
# MAIN APP LOOP
# =========================================================
def run_application():
    db = load_database()

    lcd = init_lcd()
    keypad = init_keypad()
    rfid = init_rfid()
    buzzer = init_buzzer()

    flush_keypad(keypad)
    lcd_message(lcd, "System ready", "", 0.8)
    log_event("system", "INFO", "application_started")

    while True:
        db = load_database()

        user = login_flow(lcd, keypad, buzzer, db)
        if user is None:
            time.sleep(MAIN_LOOP_DELAY)
            continue

        choice = wait_for_menu_choice(lcd, keypad, user["role"])

        db = load_database()

        if choice == "1":
            log_event("menu", "INFO", f"user={user['password']} role={user['role']} selected=unlock")
            unlock_flow(lcd, rfid, buzzer, user)
        elif choice == "2":
            log_event("menu", "INFO", f"user={user['password']} role={user['role']} selected=lock")
            lock_flow(lcd, keypad, buzzer, user, db)
        elif choice == "3":
            log_event("menu", "INFO", f"user={user['password']} role={user['role']} selected=add_user")
            add_user_flow(lcd, keypad, rfid, buzzer, db, user)
        elif choice == "4":
            log_event("menu", "INFO", f"user={user['password']} role={user['role']} selected=remove_user")
            remove_user_flow(lcd, keypad, rfid, buzzer, db, user)

        time.sleep(MAIN_LOOP_DELAY)


# =========================================================
# OUTER CRASH WRAPPER
# =========================================================
def main():
    while True:
        try:
            run_application()
        except KeyboardInterrupt:
            raise
        except Exception as exc:
            try:
                log_event("system", "CRASH", f"message={str(exc)}")
            except Exception:
                pass

            try:
                lcd = init_lcd()
                lcd_message(lcd, "System error", "Restarting...", 1.5)
            except Exception:
                pass

            time.sleep(1.5)


if __name__ == "__main__":
    main()

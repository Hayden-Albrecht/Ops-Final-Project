def init_lcd():
    lcd = qwiic_serlcd.QwiicSerlcd()
    if not lcd.is_connected():
        raise RuntimeError("SerLCD not connected")
    lcd.begin()
    time.sleep(0.2)
    set_backlight(lcd, *DEFAULT_BACKLIGHT)
    time.sleep(0.1)
    lcd.clearScreen()
    time.sleep(0.2)
    return lcd


def init_keypad():
    keypad = qwiic_keypad.QwiicKeypad()
    if not keypad.is_connected():
        raise RuntimeError("Keypad not connected")
    keypad.begin()
    return keypad


def init_rfid():
    rfid = qwiic_rfid.QwiicRFID()
    if not rfid.is_connected():
        raise RuntimeError("RFID reader not connected")
    rfid.begin()
    return rfid


def init_buzzer():
    buzzer = qwiic_buzzer.QwiicBuzzer()
    if not buzzer.is_connected():
        raise RuntimeError("Buzzer not connected")
    buzzer.begin()
    return buzzer


# =========================================================
# LCD / BACKLIGHT HELPERS
# =========================================================
def set_backlight(lcd, r: int, g: int, b: int) -> None:
    try:
        lcd.setBacklight(r, g, b)
    except Exception:
        pass


def restore_default_backlight(lcd) -> None:
    set_backlight(lcd, *DEFAULT_BACKLIGHT)


def flash_backlight(lcd, color: tuple, flashes: int = 2, on_time: float = 0.16, off_time: float = 0.10) -> None:
    for _ in range(flashes):
        set_backlight(lcd, *color)
        time.sleep(on_time)
        restore_default_backlight(lcd)
        time.sleep(off_time)


def _pad_16(text: str) -> str:
    return (text or "")[:16].ljust(16)


def lcd_show(lcd, line1: str = "", line2: str = "", force: bool = False):
    global _last_lcd_line1, _last_lcd_line2, _last_lcd_time

    now = time.time()
    line1 = _pad_16(line1)
    line2 = _pad_16(line2)

    changed = (line1 != _last_lcd_line1) or (line2 != _last_lcd_line2)

    if not changed and not force:
        return

    if not force and (now - _last_lcd_time) < LCD_MIN_UPDATE_INTERVAL:
        return

    try:
        if force or line1 != _last_lcd_line1:
            lcd.setCursor(0, 0)
            time.sleep(0.03)
            lcd.print(line1)
            time.sleep(0.05)

        if force or line2 != _last_lcd_line2:
            lcd.setCursor(0, 1)
            time.sleep(0.03)
            lcd.print(line2)
            time.sleep(0.05)

        _last_lcd_line1 = line1
        _last_lcd_line2 = line2
        _last_lcd_time = time.time()

    except Exception:
        time.sleep(0.3)


def lcd_message(lcd, line1: str = "", line2: str = "", pause: float = POST_MESSAGE_DELAY):
    lcd_show(lcd, line1, line2, force=True)
    time.sleep(pause)


# =========================================================
# BUZZER HELPERS
# =========================================================
def _try_configure_buzzer(buzzer, frequency_hz: int, duration_ms: int) -> bool:
    for method_name in ("configureBuzzer", "configure_buzzer"):
        method = getattr(buzzer, method_name, None)
        if callable(method):
            method(frequency_hz, duration_ms)
            return True

    set_freq = getattr(buzzer, "set_frequency", None)
    set_dur = getattr(buzzer, "set_duration", None)
    if callable(set_freq) and callable(set_dur):
        set_freq(frequency_hz)
        set_dur(duration_ms)
        return True

    return False


def beep(buzzer, frequency_hz: int, duration_ms: int):
    _try_configure_buzzer(buzzer, frequency_hz, duration_ms)
    buzzer.on()
    time.sleep(duration_ms / 1000.0)
    buzzer.off()
    time.sleep(0.12)


def success_beep(buzzer):
    beep(buzzer, 2500, 140)


def fail_beep(buzzer):
    beep(buzzer, 350, 500)


def success_feedback(lcd, buzzer):
    flash_backlight(lcd, GOOD_FLASH, flashes=2)
    success_beep(buzzer)


def failure_feedback(lcd, buzzer):
    flash_backlight(lcd, BAD_FLASH, flashes=2)
    fail_beep(buzzer)


# =========================================================
# KEYPAD HELPERS
# =========================================================
def flush_keypad(keypad, seconds: float = 0.8):
    end = time.time() + seconds
    while time.time() < end:
        keypad.update_fifo()
        _ = keypad.get_button()
        time.sleep(KEYPAD_POLL_DELAY)


def read_keypad_char(keypad) -> Optional[str]:
    keypad.update_fifo()
    button = keypad.get_button()

    if not button:
        return None

    try:
        return chr(button)
    except TypeError:
        return str(button)


def get_passcode_from_keypad(
    lcd,
    keypad,
    timeout_s: int,
    prompt1: str = "Enter passcode",
    prompt2: str = "then press #"
) -> Optional[str]:
    entered = ""
    last_masked = None
    start = time.time()

    lcd_show(lcd, prompt1, prompt2, force=True)

    while time.time() - start < timeout_s:
        ch = read_keypad_char(keypad)

        if ch is None:
            time.sleep(KEYPAD_POLL_DELAY)
            continue

        if ch == "#":
            time.sleep(POST_KEY_DELAY)
            return entered

        if ch == "*":
            entered = ""
        elif ch.isdigit():
            entered += ch

        masked = "*" * len(entered)
        if masked != last_masked:
            lcd_show(lcd, prompt1, masked)
            last_masked = masked

        time.sleep(POST_KEY_DELAY)

    return None


def get_role_selection(lcd, keypad, allowed_roles: List[str], timeout_s: int = 20) -> Optional[str]:
    mapping = {}
    screens = []

    if ROLE_EMPLOYEE in allowed_roles:
        mapping["1"] = ROLE_EMPLOYEE
        screens.append(("1:Employee", "Press 1"))

    if ROLE_MANAGER in allowed_roles:
        mapping["2"] = ROLE_MANAGER
        screens.append(("2:Manager", "Press 2"))

    if ROLE_ADMIN in allowed_roles:
        mapping["3"] = ROLE_ADMIN
        screens.append(("3:Admin", "Press 3"))

    start = time.time()
    idx = 0
    last_change = 0.0

    while time.time() - start < timeout_s:
        now = time.time()

        if screens and (now - last_change >= 2.5):
            lcd_show(lcd, screens[idx][0], screens[idx][1])
            idx = (idx + 1) % len(screens)
            last_change = now

        ch = read_keypad_char(keypad)
        if ch in mapping:
            time.sleep(POST_KEY_DELAY)
            return mapping[ch]

        time.sleep(KEYPAD_POLL_DELAY)

    return None


# =========================================================
# RFID HELPERS
# =========================================================
def read_rfid_once(rfid) -> Optional[str]:
    raw_tag = rfid.get_tag()

    if raw_tag is None:
        return None

    tag = normalize_tag(raw_tag)

    if tag in {"", "NONE", "0", "00", "0000", "000000", "0000000000"}:
        return None

    return tag


def wait_for_rfid_scan(lcd, rfid, prompt1: str, prompt2: str, timeout_s: int) -> Optional[str]:
    lcd_show(lcd, prompt1, prompt2, force=True)

    start = time.time()
    first_real_tag = None
    seen_count = 0

    while time.time() - start < timeout_s:
        tag = read_rfid_once(rfid)

        if tag is not None:
            if first_real_tag is None:
                first_real_tag = tag
                seen_count = 1
            elif tag == first_real_tag:
                seen_count += 1
            else:
                first_real_tag = tag
                seen_count = 1

            if seen_count >= 1:
                return first_real_tag

        time.sleep(RFID_POLL_DELAY)

    return None


# =========================================================
# AUTH HELPERS
# =========================================================
def login_flow(lcd, keypad, buzzer, db: Dict[str, Any]) -> Optional[Dict[str, Any]]:
    password = get_passcode_from_keypad(
        lcd, keypad, PASSCODE_TIMEOUT_SECONDS,
        "Startup password", "then press #"
    )

    if password is None:
        lcd_message(lcd, "Password timed", "out", 1.0)
        failure_feedback(lcd, buzzer)
        log_event("login", "FAIL", "reason=password_timeout")
        return None

    user = find_user_by_password(db, password)
    if user is None:
        lcd_message(lcd, "Invalid password", "", 1.0)
        failure_feedback(lcd, buzzer)
        log_event("login", "FAIL", f"reason=invalid_password password={password}")
        return None

    lcd_message(lcd, "Role:", user["role"], 1.0)
    success_beep(buzzer)
    restore_default_backlight(lcd)
    log_event("login", "SUCCESS", f"password={user['password']} role={user['role']}")
    return user


def reauth_password_and_rfid(lcd, keypad, rfid, buzzer, db: Dict[str, Any], expected_user: Dict[str, Any]) -> bool:
    password = get_passcode_from_keypad(
        lcd, keypad, PASSCODE_TIMEOUT_SECONDS,
        "Re-enter pass", "then press #"
    )

    if password is None:
        lcd_message(lcd, "Password timed", "out", 1.0)
        failure_feedback(lcd, buzzer)
        log_event("reauth", "FAIL", f"user={expected_user['password']} reason=password_timeout")
        return False

    if password != expected_user["password"]:
        lcd_message(lcd, "Bad password", "", 1.0)
        failure_feedback(lcd, buzzer)
        log_event("reauth", "FAIL", f"user={expected_user['password']} reason=bad_password entered={password}")
        return False

    tag = wait_for_rfid_scan(
        lcd, rfid,
        "Scan your RFID",
        "for auth",
        RFID_SCAN_TIMEOUT_SECONDS
    )

    if tag is None:
        lcd_message(lcd, "RFID timed out", "", 1.0)
        failure_feedback(lcd, buzzer)
        log_event("reauth", "FAIL", f"user={expected_user['password']} reason=rfid_timeout")
        return False

    if normalize_tag(tag) != normalize_tag(expected_user["rfid"]):
        lcd_message(lcd, "Invalid RFID", "", 1.0)
        failure_feedback(lcd, buzzer)
        log_event("reauth", "FAIL", f"user={expected_user['password']} reason=bad_rfid scanned={normalize_tag(tag)}")
        return False

    lcd_message(lcd, "Authorized", "", 0.8)
    success_feedback(lcd, buzzer)
    log_event("reauth", "SUCCESS", f"user={expected_user['password']} role={expected_user['role']}")
    return True



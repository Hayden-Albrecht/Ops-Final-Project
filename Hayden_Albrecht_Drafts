def add_user_flow(lcd, keypad, rfid, buzzer, db: Dict[str, Any], logged_in_user: Dict[str, Any]):
    if not reauth_password_and_rfid(lcd, keypad, rfid, buzzer, db, logged_in_user):
        log_event("add_user", "FAIL", f"by={logged_in_user['password']} role={logged_in_user['role']} reason=reauth_failed")
        return

    if logged_in_user["role"] == ROLE_MANAGER:
        new_role = ROLE_EMPLOYEE
        lcd_message(lcd, "Adding role:", "employee", 1.0)
    else:
        lcd_message(lcd, "Choose new role", "1E 2M 3A", 1.0)
        new_role = get_role_selection(lcd, keypad, [ROLE_EMPLOYEE, ROLE_MANAGER, ROLE_ADMIN], 20)

        if new_role is None:
            lcd_message(lcd, "Role timeout", "", 1.0)
            failure_feedback(lcd, buzzer)
            log_event("add_user", "FAIL", f"by={logged_in_user['password']} role={logged_in_user['role']} reason=role_timeout")
            return

    new_password = get_passcode_from_keypad(
        lcd, keypad, PASSCODE_TIMEOUT_SECONDS,
        "New user pass", "then press #"
    )

    if not new_password:
        lcd_message(lcd, "Bad password", "entry", 1.0)
        failure_feedback(lcd, buzzer)
        log_event("add_user", "FAIL", f"by={logged_in_user['password']} role={logged_in_user['role']} reason=empty_password")
        return

    if len(new_password) < 4:
        lcd_message(lcd, "Pass too short", "min 4 digits", 1.0)
        failure_feedback(lcd, buzzer)
        log_event("add_user", "FAIL", f"by={logged_in_user['password']} role={logged_in_user['role']} reason=password_too_short")
        return

    if find_user_by_password(db, new_password) is not None:
        lcd_message(lcd, "Password exists", "", 1.0)
        failure_feedback(lcd, buzzer)
        log_event("add_user", "FAIL", f"by={logged_in_user['password']} role={logged_in_user['role']} reason=password_exists new_password={new_password}")
        return

    new_tag = wait_for_rfid_scan(
        lcd, rfid,
        "Scan new RFID",
        "for new user",
        RFID_SCAN_TIMEOUT_SECONDS
    )

    if new_tag is None:
        lcd_message(lcd, "No RFID scan", "", 1.0)
        failure_feedback(lcd, buzzer)
        log_event("add_user", "FAIL", f"by={logged_in_user['password']} role={logged_in_user['role']} reason=rfid_timeout")
        return

    new_tag = normalize_tag(new_tag)

    if find_user_by_rfid(db, new_tag) is not None:
        lcd_message(lcd, "RFID exists", "", 1.0)
        failure_feedback(lcd, buzzer)
        log_event("add_user", "FAIL", f"by={logged_in_user['password']} role={logged_in_user['role']} reason=rfid_exists new_rfid={new_tag}")
        return

    try:
        add_user(db, new_password, new_tag, new_role)
        lcd_message(lcd, "User added", new_role, 1.2)
        success_feedback(lcd, buzzer)
        log_event("add_user", "SUCCESS", f"by={logged_in_user['password']} by_role={logged_in_user['role']} new_password={new_password} new_rfid={new_tag} new_role={new_role}")
    except Exception as exc:
        lcd_message(lcd, "Add failed", str(exc)[:16], 1.2)
        failure_feedback(lcd, buzzer)
        log_event("add_user", "FAIL", f"by={logged_in_user['password']} by_role={logged_in_user['role']} reason=exception message={str(exc)}")


def remove_user_flow(lcd, keypad, rfid, buzzer, db: Dict[str, Any], logged_in_user: Dict[str, Any]):
    if logged_in_user["role"] != ROLE_ADMIN:
        lcd_message(lcd, "Not allowed", "", 1.0)
        failure_feedback(lcd, buzzer)
        log_event("remove_user", "FAIL", f"by={logged_in_user['password']} role={logged_in_user['role']} reason=not_admin")
        return

    if not reauth_password_and_rfid(lcd, keypad, rfid, buzzer, db, logged_in_user):
        log_event("remove_user", "FAIL", f"by={logged_in_user['password']} role={logged_in_user['role']} reason=reauth_failed")
        return

    remove_password = get_passcode_from_keypad(
        lcd, keypad, PASSCODE_TIMEOUT_SECONDS,
        "Remove passcode", "then press #"
    )

    if not remove_password:
        lcd_message(lcd, "Bad password", "entry", 1.0)
        failure_feedback(lcd, buzzer)
        log_event("remove_user", "FAIL", f"by={logged_in_user['password']} role={logged_in_user['role']} reason=empty_remove_password")
        return

    remove_tag = wait_for_rfid_scan(
        lcd, rfid,
        "Scan user's RFID",
        "to remove",
        RFID_SCAN_TIMEOUT_SECONDS
    )

    if remove_tag is None:
        lcd_message(lcd, "No RFID scan", "", 1.0)
        failure_feedback(lcd, buzzer)
        log_event("remove_user", "FAIL", f"by={logged_in_user['password']} role={logged_in_user['role']} reason=rfid_timeout")
        return

    remove_tag = normalize_tag(remove_tag)

    target = None
    for user in db["users"]:
        if user.get("active", True) and user["password"] == remove_password and normalize_tag(user["rfid"]) == remove_tag:
            target = user
            break

    if target is None:
        lcd_message(lcd, "User not found", "", 1.0)
        failure_feedback(lcd, buzzer)
        log_event("remove_user", "FAIL", f"by={logged_in_user['password']} role={logged_in_user['role']} reason=user_not_found remove_password={remove_password} remove_rfid={remove_tag}")
        return

    if target["password"] == logged_in_user["password"] and normalize_tag(target["rfid"]) == normalize_tag(logged_in_user["rfid"]):
        lcd_message(lcd, "Cannot remove", "current admin", 1.0)
        failure_feedback(lcd, buzzer)
        log_event("remove_user", "FAIL", f"by={logged_in_user['password']} role={logged_in_user['role']} reason=cannot_remove_self")
        return

    try:
        removed = remove_user(db, remove_password, remove_tag)
        if removed:
            lcd_message(lcd, "User removed", "", 1.0)
            success_feedback(lcd, buzzer)
            log_event("remove_user", "SUCCESS", f"by={logged_in_user['password']} by_role={logged_in_user['role']} removed_password={remove_password} removed_rfid={remove_tag} removed_role={target['role']}")
        else:
            lcd_message(lcd, "Remove failed", "", 1.0)
            failure_feedback(lcd, buzzer)
            log_event("remove_user", "FAIL", f"by={logged_in_user['password']} by_role={logged_in_user['role']} reason=remove_returned_false")
    except Exception as exc:
        lcd_message(lcd, "Remove failed", str(exc)[:16], 1.2)
        failure_feedback(lcd, buzzer)
        log_event("remove_user", "FAIL", f"by={logged_in_user['password']} by_role={logged_in_user['role']} reason=exception message={str(exc)}")


# =========================================================
# MAIN APP LOOP
# =========================================================
def run_application():
    db = load_database()

    lcd = init_lcd()
    keypad = init_keypad()
    rfid = init_rfid()
    buzzer = init_buzzer()

    flush_keypad(keypad)
    lcd_message(lcd, "System ready", "", 1.0)
    restore_default_backlight(lcd)
    log_event("system", "INFO", "application_started")

    while True:
        db = load_database()

        user = login_flow(lcd, keypad, buzzer, db)
        if user is None:
            time.sleep(MAIN_LOOP_DELAY)
            continue

        choice = wait_for_menu_choice(lcd, keypad, user["role"], MENU_TIMEOUT_SECONDS)

        if choice is None:
            lcd_message(lcd, "Menu timeout", "", 1.0)
            failure_feedback(lcd, buzzer)
            log_event("menu", "FAIL", f"user={user['password']} role={user['role']} reason=timeout")
            time.sleep(MAIN_LOOP_DELAY)
            continue

        db = load_database()

        if choice == "1":
            log_event("menu", "INFO", f"user={user['password']} role={user['role']} selected=unlock")
            unlock_flow(lcd, rfid, buzzer, user)
        elif choice == "2":
            log_event("menu", "INFO", f"user={user['password']} role={user['role']} selected=lock")
            lock_flow(lcd, keypad, buzzer, user, db)
        elif choice == "3":
            log_event("menu", "INFO", f"user={user['password']} role={user['role']} selected=add_user")
            add_user_flow(lcd, keypad, rfid, buzzer, db, user)
        elif choice == "4":
            log_event("menu", "INFO", f"user={user['password']} role={user['role']} selected=remove_user")
            remove_user_flow(lcd, keypad, rfid, buzzer, db, user)

        restore_default_backlight(lcd)
        time.sleep(MAIN_LOOP_DELAY)


# =========================================================
# OUTER CRASH WRAPPER
# =========================================================
def main():
    while True:
        lcd = None
        buzzer = None

        try:
            run_application()
        except KeyboardInterrupt:
            raise
        except Exception as exc:
            try:
                log_event("system", "CRASH", f"message={str(exc)}")
            except Exception:
                pass

            try:
                lcd = init_lcd()
                buzzer = init_buzzer()
                lcd_message(lcd, "System error", "Restarting...", 2.0)
                failure_feedback(lcd, buzzer)
            except Exception:
                pass

            time.sleep(2.0)


if __name__ == "__main__":
    main()

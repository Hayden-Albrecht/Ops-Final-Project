def build_menu_screens_for_role(role: str) -> List[tuple]:
    if role == ROLE_EMPLOYEE:
        return [
            ("1:Unlock", "Press 1"),
            ("2:Lock", "Press 2"),
        ]

    if role == ROLE_MANAGER:
        return [
            ("1:Unlock", "Press 1"),
            ("2:Lock", "Press 2"),
            ("3:Add user", "Press 3"),
        ]

    if role == ROLE_ADMIN:
        return [
            ("1:Unlock", "Press 1"),
            ("2:Lock", "Press 2"),
            ("3:Add user", "Press 3"),
            ("4:Remove user", "Press 4"),
        ]

    return []


def valid_choices_for_role(role: str) -> set:
    if role == ROLE_EMPLOYEE:
        return {"1", "2"}
    if role == ROLE_MANAGER:
        return {"1", "2", "3"}
    if role == ROLE_ADMIN:
        return {"1", "2", "3", "4"}
    return set()


def wait_for_menu_choice(lcd, keypad, role: str, timeout_s: int) -> Optional[str]:
    screens = build_menu_screens_for_role(role)
    valid = valid_choices_for_role(role)

    start = time.time()
    idx = 0
    last_change = 0.0

    while time.time() - start < timeout_s:
        now = time.time()

        if screens and (now - last_change >= 2.5):
            line1, line2 = screens[idx]
            lcd_show(lcd, line1, line2)
            idx = (idx + 1) % len(screens)
            last_change = now

        ch = read_keypad_char(keypad)
        if ch in valid:
            time.sleep(POST_KEY_DELAY)
            return ch

        time.sleep(KEYPAD_POLL_DELAY)

    return None


